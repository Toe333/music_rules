{
  "name": "Dre 1990s Gangsta",
  "description": "G-funk minor loop: boom-bap drums, chromatic walking bass into downbeats, Moog blues-scale lead, dark minor vamp.",
  "tempo_bpm": 92,
  "swing": 0.55,
  "meter": "4/4",
  "key": { "tonic": "A", "mode": "natural_minor" },

  "harmony": {
    "chord_vamp": [
      { "chord": "Am", "bars": 2 },
      { "chord": "F",  "bars": 2 }
    ],
    "voicing": {
      "Am": [57, 60, 64],
      "F":  [53, 57, 60]
    },
    "chord_roots": { "Am": "A", "F": "F" }
  },

  "drums": {
    "pattern_resolution": "8th",
    "pattern_spec": "K H S K K H S H",
    "pattern": {
      "kick":  [1, 0, 0, 1, 1, 0, 0, 0],
      "snare": [0, 0, 1, 0, 0, 0, 1, 0],
      "hihat": [0, 1, 0, 0, 0, 1, 0, 1]
    },
    "midi_notes": { "kick": 36, "snare": 38, "hihat": 42 },
    "velocity":   { "kick": 110, "snare": 105, "hihat": 70 },
    "humanize_velocity": 8
  },

  "bass": {
    "program": 38,
    "octave": 2,
    "scale_pool": ["A", "B", "C", "D", "E", "F", "G"],
    "rules": {
      "downbeat_must_be_chord_root": true,
      "approach_downbeat_with_chromatic_step": true,
      "chromatic_approach_direction": "below_or_above",
      "syncopation_probability": 0.4,
      "rest_probability": 0.15,
      "max_leap_semitones": 7
    },
    "rhythm_cells_beats": [
      [1.0, 0.5, 0.5, 1.0, 0.5, 0.5],
      [1.0, 0.5, 0.5, 0.5, 0.5, 1.0],
      [0.5, 0.5, 1.0, 0.5, 0.5, 1.0],
      [1.5, 0.5, 1.0, 1.0]
    ],
    "velocity": 95
  },

  "lead": {
    "program": 81,
    "octave": 5,
    "scale_pool": ["A", "C", "D", "Eb", "E", "G"],
    "rules": {
      "active_on_bars_in_phrase": [1, 3],
      "phrase_length_beats": [2, 3, 4],
      "max_leap_semitones": 5,
      "emphasize_blue_note": "Eb",
      "rest_probability_per_bar": 0.5
    },
    "rhythm_cells_beats": [
      [1.0, 1.0, 2.0],
      [0.5, 0.5, 1.0, 2.0],
      [2.0, 1.0, 1.0],
      [4.0]
    ],
    "velocity": 88
  },

  "chord_pad": {
    "program": 88,
    "velocity": 55,
    "octave_offset": 0
  },

  "form": {
    "structure": ["A", "A", "A", "B"],
    "bars_per_section": 4,
    "B_section": {
      "lead_active_on_all_bars": true,
      "drum_velocity_boost": 12
    }
  }
}
